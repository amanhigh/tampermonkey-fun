{
  "compilerOptions": {
    // Keep the compilation and module settings
    "rootDir": "./src",
    "outDir": "./dist/",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    // Keep the strict type checking bundle
    "strict": true, // This enables many strict checks in one setting
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Keep source map and declaration settings
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noImplicitReturns": true,
    "types": ["greasemonkey", "jquery", "node", "jest"]
  },
  "include": [
    "src/**/*" // Include all files in src directory
  ],
  "exclude": [
    "node_modules", // Exclude node_modules
    "dist" // Exclude dist directory
  ]
}